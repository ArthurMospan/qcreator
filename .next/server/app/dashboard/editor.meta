{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/editor/layout,_N_T_/dashboard/editor/page,_N_T_/dashboard/editor"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/editor/__PAGE__",
    "/dashboard/editor",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}